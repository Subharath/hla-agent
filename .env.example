# ══════════════════════════════════════════════════
# HLA Agent — Environment Configuration
# Copy this file to .env and fill in your API keys
# ══════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────
# Choose one: "groq", "deepseek", "gemini", "ollama"
LLM_PROVIDER=gemini

# ── API Keys ─────────────────────────────────────
# Google Gemini (commercial, free tier available)
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq (open-source models, free tier)
# Get your key: https://console.groq.com
GROQ_API_KEY=your-groq-key-here

# DeepSeek (open-source, very cheap)
# Get your key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key-here

# ── Ollama (Local, optional) ────────────────────
# Only needed if LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
